# Phlame .env template — full procedure: docs/mcp-setup.md ("First-time setup"
# and "Host-owned deployment"). TWO instances of this file exist:
#
#   worktree .env (this repo)          DEV ONLY — used when phorge runs from the
#                                      worktree (npm run phorge:stack / :up) and
#                                      VISIBLE to the agent container through the
#                                      repo mount: only what the agent may see.
#   deployment .env (../phlame-phorge) owns the tokens under O1 — feeds the
#                                      deployed phorge AND the compose variable
#                                      interpolation; additionally sets
#                                      PHLAME_WORKTREE. Never inside a container.
#
# While both modes are in use, PHORGE_TOKEN and CLAUDE_CODE_OAUTH_TOKEN must
# MATCH between the two files (the agent container's generated config has to
# match whichever phorge server answers on 4201).

# both files — random secret for the phorge http server, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
PHORGE_TOKEN=

# both files — from `claude setup-token`: claude's subscription login for the
# agent container (long-lived token, no credential files shared)
CLAUDE_CODE_OAUTH_TOKEN=

# deployment .env ONLY — absolute path to the agent worktree the runners test
# and the agent edits (forward slashes work on Windows). Unset = "." (dev mode).
# PHLAME_WORKTREE=C:/Users/you/Projects/phlame

# optional, host-side tooling only (e.g. agy on the host reading .agents/mcp.json)
# PHORGE_URL=http://localhost:4201/mcp
