{
  "name": "phlame",
  "version": "0.1.0",
  "license": "AGPLv3",
  "type": "module",
  "scripts": {
    "start": "vp dev",
    "test-engine": "cd engine && npm test",
    "tsc-engine": "cd engine && npm run tsc",
    "build-engine": "cd engine && npm run build",
    "build": "vp build",
    "test": "vp test run && cd engine && npx vitest run",
    "coverage": "vp test run --coverage && cd engine && npx vitest run --coverage",
    "play": "playwright test --ui",
    "e2e": "playwright test",
    "ci": "playwright test",
    "lint": "vp lint -c .oxlintrc.json && vp fmt --check",
    "tsc": "tsc -p tsconfig.spec.json --noEmit",
    "preview": "tsx src/server",
    "console": "tsx tools/console/main.ts",
    "mcp": "tsx tools/mcp/server.ts",
    "phorge": "tsx tools/phorge/server.ts",
    "phorge:build": "esbuild tools/phorge/server.http.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/phorge/server.http.js",
    "phorge:http": "npm run phorge:build && node --env-file=.env dist/phorge/server.http.js",
    "phorge:stack": "tsx tools/phorge/stack.ts",
    "phorge:up": "tsx tools/phorge/stack.ts --detached",
    "phorge:down": "tsx tools/phorge/stack.ts --down",
    "containers:build": "docker compose -f compose.test.yml build",
    "containers:down": "docker compose -f compose.test.yml down",
    "test:docker": "docker compose -f compose.test.yml -f compose.test.dev.yml run --rm runner npm test",
    "tsc:docker": "docker compose -f compose.test.yml -f compose.test.dev.yml run --rm runner npm run tsc",
    "lint:docker": "docker compose -f compose.test.yml -f compose.test.dev.yml run --rm runner npm run lint",
    "e2e:docker": "docker compose -f compose.test.yml -f compose.test.dev.yml run --rm playwright npx playwright test",
    "screenshot:docker": "docker compose -f compose.test.yml -f compose.test.dev.yml run --rm playwright npx playwright test screenshot.spec.ts --project=chromium",
    "agents:build": "docker compose -f compose.agents.yml build",
    "agents:up": "docker compose -f compose.agents.yml up -d agent",
    "agents:down": "docker compose -f compose.agents.yml down",
    "agent": "tsx tools/agent.ts"
  },
  "private": true,
  "resolutions": {},
  "devDependencies": {
    "@hono/vite-dev-server": "^0.26.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.0.13",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@joist/di": "^4.10.2",
    "hono": "^4.12.28",
    "html-element": "^2.3.1",
    "htmx.org": "^2.0.10",
    "nanoid": "^5.1.16",
    "signal-polyfill": "^0.2.2",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vitest": "4.1.10"
  }
}
