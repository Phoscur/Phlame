{
  "name": "phlame",
  "version": "0.1.0",
  "license": "AGPLv3",
  "type": "module",
  "scripts": {
    "start": "vite",
    "test-engine": "cd engine && npm test",
    "tsc-engine": "cd engine && npm run tsc",
    "build-engine": "cd engine && npm run build",
    "lint-engine": "eslint engine/src",
    "build": "vite build",
    "test": "vitest run && cd engine && npx vitest run",
    "coverage": "vitest run --coverage && cd engine && npx vitest run --coverage",
    "play": "playwright test --ui",
    "e2e": "playwright test",
    "ci": "playwright test",
    "lint": "oxlint && eslint",
    "tsc": "tsc -p tsconfig.spec.json --noEmit",
    "preview": "tsx src/server"
  },
  "private": true,
  "resolutions": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.0.13",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "prettier-eslint": "^17.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@joist/di": "^4.10.2",
    "hono": "^4.12.28",
    "html-element": "^2.3.1",
    "htmx.org": "^2.0.10",
    "nanoid": "^5.1.16",
    "signal-polyfill": "^0.2.2",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
