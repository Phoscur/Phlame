{
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "experimentalDecorators": false,
    "importHelpers": true,
    // ES2022 (not ESNext) so esbuild/tsx down-level the standard decorators
    // @joist/di uses — at esnext esbuild passes them through untransformed.
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "ESNext.Decorators", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    // paths resolve relative to this tsconfig (no baseUrl — deprecated in TS 6, gone in 7)
    "paths": { "@phlame/engine": ["./engine/src/index.ts"] },
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "allowJs": false,
    "strict": true,
    "types": ["vite/client", "vitest", "node", "hono"],
    "useDefineForClassFields": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true
  },
  "files": [],
  "include": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.spec.json" }],
  "compileOnSave": false,
  "exclude": ["node_modules", "tmp"]
}
